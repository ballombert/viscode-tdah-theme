        "meta.preprocessor.cs",
        "keyword.preprocessor.cs"
      ],
      "settings": { "foreground": "{{COLOR_ACCENT_PURPLE}}" }
    },
    {
      "name": "L - C# null et constantes",
      "scope": ["constant.language.null.cs"],
      "settings": { "foreground": "{{COLOR_ACCENT_PURPLE}}" }
    },
    {
      "name": "L - C# interpolation chaines",
      "scope": [
        "punctuation.definition.interpolation.begin.cs",
        "punctuation.definition.interpolation.end.cs"
      ],
      "settings": { "foreground": "{{COLOR_ACCENT_BLUE}}" }
    },
    {
      "name": "L - C# LINQ keywords",
      "scope": ["keyword.query.cs"],
      "settings": { "foreground": "{{COLOR_ACCENT_BLUE}}" }
    },

    // ─── M - Regex et templates ───────────────────────────────────────────────

    {
      "name": "M - Regexp",
      "scope": [
        "string.regexp",
        "constant.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": { "foreground": "{{COLOR_ACCENT_PURPLE}}" }
    }

  ],
