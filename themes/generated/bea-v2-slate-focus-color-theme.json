        "entity.name.type.alias.rust",
        "entity.name.type.trait.rust"
      ],
      "settings": { "foreground": "#5AB6C4" }
    },
    {
      "name": "J - Rust unsafe",
      "scope": [
        "storage.modifier.unsafe.rust",
        "keyword.other.unsafe.rust"
      ],
      "settings": { "foreground": "#DF7280" }
    },
    {
      "name": "J - Rust chemin module",
      "scope": ["meta.path.rust"],
      "settings": { "foreground": "#E1E7EE" }
    },

    // ─── K - Go ───────────────────────────────────────────────────────────────

    {
      "name": "K - Go fonctions builtin",
      "scope": ["support.function.builtin.go"],
      "settings": { "foreground": "#76C9BC" }
    },
    {
      "name": "K - Go package",
      "scope": ["entity.name.package.go"],
      "settings": { "foreground": "#5AB6C4" }
    },
    {
      "name": "K - Go types",
