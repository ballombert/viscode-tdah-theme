    "property": "#7BA9F2",
    "enumMember": "#B49ADF",
    "event": "#76C9BC",
    "function": "#76C9BC",
    "method": "#76C9BC",
    "macro": "#76C9BC",
    "decorator": "#B49ADF",
    "keyword": "#7BA9F2",
    "comment": "#748394",
    "string": "#93C582",
